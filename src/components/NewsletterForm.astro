---
interface Props {
  heading?: string;
  subheading?: string;
  compact?: boolean;
}
const {
  heading = 'Join the weekly newsletter',
  subheading = 'One bold email each week. No fluff. Unsubscribe anytime.',
  compact = false,
} = Astro.props;
---
<section class={`${compact ? 'py-12' : 'py-16'} bg-black text-white`}>
  <div class="max-w-content mx-auto px-6 text-center">
    <h2 class="text-4xl md:text-5xl mb-4">{heading}</h2>
    <p class="text-white/80 mb-8 max-w-xl mx-auto">{subheading}</p>
    <div class="max-w-md mx-auto">
      <script
        async
        src="https://subscribe-forms.beehiiv.com/v3/loader.js"
        data-beehiiv-form="f6988907-9913-4e7a-a797-ba41c345c6a7"
      ></script>
    </div>
  </div>
</section>
